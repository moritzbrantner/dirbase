{
  "name": "folder-server",
  "version": "0.1.0",
  "description": "JavaScript wrapper around the folder-server Rust binary",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "bin": {
    "folder-server": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "clean": "bun scripts/clean-package-output.mjs",
    "build:js": "bun esbuild.config.mjs",
    "build:rust": "cargo build --release --manifest-path ../Cargo.toml",
    "copy:binary": "bun scripts/copy-rust-binary.mjs",
    "build": "bun run clean && bun run build:js && bun run build:rust && bun run copy:binary",
    "prepack": "bun run build"
  },
  "keywords": [
    "rust",
    "json-server",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
