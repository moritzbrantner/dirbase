{
  "name": "dirbase-overview-ui",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "build": "bunx tailwindcss -c ./tailwind.config.mjs -i ./src/styles.css -o ./src/tailwind.generated.css --minify && bun esbuild.config.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=istanbul",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.cjs",
    "test:e2e:ui": "playwright test --config=playwright.config.cjs --ui"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "4.1.7",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "vite": "^8.0.5"
  }
}
