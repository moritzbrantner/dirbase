{
  "name": "dirbase",
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "cargo run -- ./examples/school --bind 127.0.0.1:4444",
    "test": "cargo test -- --test-threads=1 && bun run --cwd ui test && bun run --cwd js test",
    "verify": "bun run format:check && bun run lint && bun run build && bash scripts/run_repo_tests.sh",
    "lint": "cargo clippy --all-targets --all-features -- -D warnings && bun run --cwd ui typecheck",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "build": "cargo build --release --all-features",
    "hygiene": "bash scripts/check_repo_hygiene.sh",
    "build:ui": "bun run --cwd ui build",
    "build:js": "bun run --cwd js build",
    "test:ui": "bun run --cwd ui test",
    "test:ui:coverage": "bun run --cwd ui test:coverage",
    "test:e2e": "bun run --cwd ui test:e2e",
    "test:e2e:ui": "bun run --cwd ui test:e2e:ui",
    "playwright": "bun run --cwd ui test:e2e:ui",
    "playwright:ui": "bun run --cwd ui test:e2e:ui"
  }
}
